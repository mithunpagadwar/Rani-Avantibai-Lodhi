{
  "entities": {
    "Post": {
      "title": "Blog Post",
      "description": "News and blog entries",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    },
    "Slider": {
      "title": "Hero Slider",
      "description": "Homepage slider items",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Setting": {
      "title": "Site Settings",
      "description": "General site configuration",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    },
    "QuickLink": {
      "title": "Quick Link",
      "description": "Footer or navigation links",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/posts/{postId}": { "schema": "Post", "description": "Blog posts collection" },
    "/sliders/{sliderId}": { "schema": "Slider", "description": "Hero sliders" },
    "/siteContent/settings": { "schema": "Setting", "description": "Site-wide settings" },
    "/quickLinks/{linkId}": { "schema": "QuickLink", "description": "Navigation links" },
    "/programs/{programId}": { "schema": "object", "description": "Trust programs and videos" },
    "/members/{memberId}": { "schema": "object", "description": "Trust committee members" }
  }
}
