rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Standard Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == "mithunpagadwar745@gmail.com" || 
         request.auth.token.email == "mithunpagadwar8@gmail.com" || 
         request.auth.token.email == "amarshahidraniavantibailodhism@gmail.com" ||
         request.auth.uid == "nyy3bsWqS6cxST094tjEByKDCa82");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Connection Test
    match /test/connection {
      allow get: if true;
    }

    // 2. Blog Posts
    match /posts/{postId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidPost(incoming());
      allow update: if isAdmin() && isValidPost(incoming());
      allow delete: if isAdmin();
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.content is string && data.content.size() <= 50000;
    }

    // 3. User Profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && request.auth.uid == userId && (
        incoming().diff(existing() == null ? {} : existing()).affectedKeys().hasOnly(['name', 'email', 'updatedAt', 'photoURL'])
      );
    }

    // 4. Hero Sliders
    match /sliders/{sliderId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // 5. Site Content (settings, about, etc.)
    match /siteContent/{contentId} {
      allow get: if true;
      allow list: if true;
      allow write: if isAdmin();
    }

    // 6. Quick Links
    match /quickLinks/{linkId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // 7. Generic Protected Collections (members, gallery, meetings, contacts, notices, certificates, programs)
    match /members/{id} { allow read: if true; allow write: if isAdmin(); }
    match /gallery/{id} { allow read: if true; allow write: if isAdmin(); }
    match /meetings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /notices/{id} { allow read: if true; allow write: if isAdmin(); }
    match /certificates/{id} { allow read: if true; allow write: if isAdmin(); }
    match /programs/{id} { allow read: if true; allow write: if isAdmin(); }
    
    // Contacts: Public can create (send a message), Admin can manage
    match /contacts/{id} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }
  }
}
